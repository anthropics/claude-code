# =====================================================
# The ONE Thing - Productivity Agent
# Copy this file to .env.local and fill in your values
# =====================================================

# Linear API Key
# Get it at: https://linear.app/settings/api > Personal API keys
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxx

# Telegram Bot
# 1. Create a bot: talk to @BotFather on Telegram, send /newbot
# 2. BotFather gives you the token below
# 3. To get TELEGRAM_CHAT_ID: start a chat with your bot, then run:
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates
#    and look for "chat": { "id": 123456789 }
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# Anthropic API Key
# Get it at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Vercel KV (Redis)
# Created automatically when you add Vercel KV storage to your project:
# vercel storage create my-kv --type kv
# Or set up manually via https://vercel.com/dashboard > Storage
KV_REST_API_URL=https://xxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Cron security secret
# A random string used to secure the cron endpoint
# Generate one with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# Optional: Claude model (default shown)
# Upgrade to claude-opus-4-6 for deeper reasoning
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Optional: Timezone for cron schedule display (default shown)
TIMEZONE=America/New_York
