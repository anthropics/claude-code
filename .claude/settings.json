{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.devcontainer/hooks/block-mnt-mount.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.devcontainer/hooks/block-mnt-in-compose.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "for t in /dev/pts/[0-9]*; do [ -w \"$t\" ] && printf '\\a' > \"$t\"; done; true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "for t in /dev/pts/[0-9]*; do [ -w \"$t\" ] && printf '\\a' > \"$t\"; done; true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "for t in /dev/pts/[0-9]*; do [ -w \"$t\" ] && printf '\\a' > \"$t\"; done; true"
          }
        ]
      }
    ]
  }
}
