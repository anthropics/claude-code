# ============================================
# TEST MODE ENVIRONMENT CONFIGURATION
# ============================================
# This configuration is for TESTING ONLY
# No real money will be processed
# Safe to experiment!

# Environment
NODE_ENV=development
PORT=3000

# Admin Contact
ADMIN_EMAIL=your-email@example.com

# Production Mode (false = test mode)
PRODUCTION_MODE=false

# ============================================
# STRIPE - TEST MODE
# ============================================
# Get test keys from: https://dashboard.stripe.com/test/apikeys
# Test keys start with: sk_test_... and pk_test_...

STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXX_replace_with_your_actual_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXX_replace_with_your_actual_test_key

# Stripe Webhook Secret (after creating webhook)
# Get from: https://dashboard.stripe.com/test/webhooks
# STRIPE_WEBHOOK_SECRET=whsec_test_1234567890abcdefghijklmnop

# ============================================
# GOOGLE GEMINI API (Optional)
# ============================================
# Free tier available at: https://makersuite.google.com/app/apikey
# Leave blank to skip AI features

GOOGLE_API_KEY=

# ============================================
# SECURITY
# ============================================
# JWT Secret for token signing
# Generated automatically by deployment script
# If running locally, generate with: openssl rand -base64 32

JWT_SECRET=your-generated-jwt-secret-here-32-chars-minimum

# ============================================
# CORS (Optional)
# ============================================
# Comma-separated list of allowed origins
# In test mode, * (all origins) is allowed
# Example: https://example.com,https://www.example.com

# ALLOWED_ORIGINS=*

# ============================================
# DATABASE (Optional - for future features)
# ============================================
# PostgreSQL connection string
# Railway will set this automatically if you add a database
# Format: postgresql://user:password@host:port/database

# DATABASE_URL=postgresql://localhost:5432/publishing_empire_test

# ============================================
# NOTES
# ============================================
# ⚠️  Test mode limitations:
# - No real money is processed
# - Use test card: 4242 4242 4242 4242
# - Any CVV, any future expiry date
# - Any billing ZIP code
#
# ✅ Test mode advantages:
# - Unlimited test transactions
# - Safe to experiment
# - Test all error scenarios
# - No compliance requirements
#
# 🔄 To switch to production:
# 1. Get live Stripe keys (sk_live_... and pk_live_...)
# 2. Set PRODUCTION_MODE=true
# 3. Update environment variables
# 4. Test with small real transaction
# 5. Monitor closely!
