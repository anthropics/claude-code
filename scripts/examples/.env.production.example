# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# ⚠️  WARNING: This is for LIVE/PRODUCTION use
# Real money will be processed!
# Double-check all values before deploying!

# Environment
NODE_ENV=production
PORT=3000

# Admin Contact
ADMIN_EMAIL=your-email@example.com

# Production Mode (true = LIVE MODE - REAL MONEY!)
PRODUCTION_MODE=true

# ============================================
# STRIPE - LIVE MODE ⚠️
# ============================================
# Get LIVE keys from: https://dashboard.stripe.com/apikeys
# Live keys start with: sk_live_... and pk_live_...
# ⚠️  Keep these SECRET! Never commit to git!

STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXX_replace_with_your_actual_live_key
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXX_replace_with_your_actual_live_key

# Stripe Webhook Secret (REQUIRED for production!)
# Get from: https://dashboard.stripe.com/webhooks
# Create endpoint: https://your-app.railway.app/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXX_replace_with_your_actual_webhook_secret

# ============================================
# GOOGLE GEMINI API (Optional but recommended)
# ============================================
# Free tier: 60 requests/minute
# Get key: https://makersuite.google.com/app/apikey

GOOGLE_API_KEY=AIzaSy...your-actual-api-key-here

# ============================================
# SECURITY
# ============================================
# JWT Secret for token signing
# CRITICAL: Use a strong, unique secret!
# Generate with: openssl rand -base64 32
# NEVER reuse across environments!

JWT_SECRET=your-strong-production-jwt-secret-min-32-chars

# ============================================
# CORS - PRODUCTION CONFIGURATION
# ============================================
# ⚠️  IMPORTANT: Restrict to your actual domains!
# Comma-separated, no spaces, full URLs with protocol
# Example: https://example.com,https://www.example.com

ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# DATABASE (Recommended for production)
# ============================================
# PostgreSQL connection string
# Add PostgreSQL in Railway for automatic setup
# Format: postgresql://user:password@host:port/database

DATABASE_URL=postgresql://user:pass@host.railway.internal:5432/railway

# ============================================
# MONITORING & LOGGING (Recommended)
# ============================================
# Sentry for error tracking (optional but recommended)
# Get DSN from: https://sentry.io
# SENTRY_DSN=https://abc123@o123456.ingest.sentry.io/123456

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# ============================================
# RATE LIMITING - PRODUCTION
# ============================================
# Requests per window (per IP)
RATE_LIMIT_MAX=100

# Window duration in minutes
RATE_LIMIT_WINDOW=15

# ============================================
# SESSION & COOKIES
# ============================================
# Session secret (for future session support)
# SESSION_SECRET=your-session-secret-here

# Cookie domain (for future cookie support)
# COOKIE_DOMAIN=.yourdomain.com

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before going live, verify:
#
# ✅ Security:
#    - All secrets are strong and unique
#    - CORS is restricted to your domains
#    - Rate limiting is enabled
#    - HTTPS is enforced
#
# ✅ Stripe:
#    - Using LIVE keys (sk_live_...)
#    - Webhook endpoint configured
#    - Webhook secret set
#    - Test with small real payment
#
# ✅ Monitoring:
#    - Check Railway logs regularly
#    - Monitor Stripe dashboard
#    - Set up alerts (optional)
#    - Error tracking enabled (optional)
#
# ✅ Compliance:
#    - Terms of Service created
#    - Privacy Policy published
#    - Refund Policy defined
#    - Business info in Stripe
#
# ✅ Backup:
#    - Database backups enabled
#    - Code in version control
#    - Deployment info saved
#    - Recovery plan documented
#
# ============================================
# PRODUCTION NOTES
# ============================================
#
# 💰 You're processing real money!
#    - Start with small test transaction
#    - Monitor first 24 hours closely
#    - Check Stripe dashboard daily
#    - Respond to disputes promptly
#
# 🔒 Security is critical:
#    - Never commit .env to git
#    - Rotate secrets regularly
#    - Monitor for suspicious activity
#    - Keep dependencies updated
#
# 📊 Monitor everything:
#    - Railway logs
#    - Stripe dashboard
#    - Error rates
#    - Transaction volume
#
# 🆘 Emergency contacts:
#    - Railway Support: https://railway.app/discord
#    - Stripe Support: https://support.stripe.com
#    - Your team: [add contact info]
#
# 🔄 For updates:
#    - Test in staging first
#    - Deploy during low traffic
#    - Monitor closely after deploy
#    - Have rollback plan ready
