{
  "description": "Intercepts destructive shell commands before execution to prevent data loss",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/guardrails.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
