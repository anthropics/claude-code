{
  "description": "Loads AGENTS.md files as fallback context when no CLAUDE.md is present",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks-handlers/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
