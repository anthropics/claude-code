{
  "description": "Warns when Bash commands navigate outside the project workspace boundary",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/workdir_guard.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
