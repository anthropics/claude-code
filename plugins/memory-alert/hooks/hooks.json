{
  "description": "Checks system memory usage after each tool call and alerts when threshold is exceeded",
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/memory-alert.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
