{
  "description": "Protects sensitive infrastructure files from accidental overwrites",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/run_sensitive_file_guard.sh\""
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/run_sensitive_file_guard.sh\""
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/run_sensitive_file_guard.sh\""
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ]
  }
}
