{
  "expo": {
    "name": "KuntotarkastusAI",
    "slug": "kuntotarkastus-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "kuntotarkastusai",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kuntotarkastus.ai"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.kuntotarkastus.ai"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Salli kameran käyttö tarkastuskuvien ottamiseen"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Salli valokuvien käyttö tarkastusraporteissa"
        }
      ]
    ]
  }
}
