{
  "name": "building-inspection-ai",
  "version": "1.0.0",
  "description": "AI-powered building inspection report system for Finnish market",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:mobile": "cd mobile && npx expo start --clear",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:expo": "concurrently \"npm run dev:backend\" \"npm run dev:mobile\"",
    "install:mobile": "cd mobile && npm install",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:backend && npm run build:frontend"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0"
  }
}
